rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── avatars/{uid}/avatar ──────────────────────────────────────────────────
    match /avatars/{uid}/avatar {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null
        && request.auth.uid == uid
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── rooms/{roomId}/files/{allPaths=**} ────────────────────────────────────
    // Any signed-in user may read room files (members need to open them in editor)
    // Any signed-in user may upload — room membership is enforced at the
    // Firestore metadata write level (fileService.js + firestore.rules)
    match /rooms/{roomId}/files/{allPaths=**} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null
        && request.resource.size <= 5 * 1024 * 1024;  // 5 MB per file
      allow delete: if request.auth != null;
    }

    // ── catch-all ─────────────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
