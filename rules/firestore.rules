rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn()   { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    // ── /users/{uid} ──────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasAll(["uid","displayName","email","provider","createdAt","updatedAt"])
        && request.resource.data.displayName is string
        && request.resource.data.provider in ["email","github","google"];
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(["displayName","avatarUrl","updatedAt"]);
      allow delete: if false;
    }

    // ── /rooms/{roomId} ───────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read:   if signedIn();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
      allow update: if signedIn();
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;

      // members
      match /members/{uid} {
        allow read:  if signedIn();
        allow write: if isOwner(uid);
      }

      // channels
      match /channels/{channelId} {
        allow read:   if signedIn();
        allow create: if signedIn();
        allow update: if signedIn();
        allow delete: if false;

        // messages
        match /messages/{messageId} {
          allow read:   if signedIn();
          allow create: if signedIn()
            && request.resource.data.senderId == request.auth.uid
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0;
          allow update: if false;
          allow delete: if false;
        }
      }

      // typing indicators
      match /typing/{uid} {
        allow read:  if signedIn();
        allow write: if isOwner(uid);
      }

      // original uploaded files
      match /files/{fileId} {
        allow read:   if signedIn();
        allow create: if signedIn()
          && request.resource.data.uploadedBy == request.auth.uid
          && request.resource.data.path is string
          && request.resource.data.name is string;
        allow update: if false;
        allow delete: if signedIn() && resource.data.uploadedBy == request.auth.uid;
      }

      // live file edits
      match /fileContents/{fileId} {
        allow read:   if signedIn();
        allow create: if signedIn();
        allow update: if signedIn();
        allow delete: if false;
      }
    }
  }
}
